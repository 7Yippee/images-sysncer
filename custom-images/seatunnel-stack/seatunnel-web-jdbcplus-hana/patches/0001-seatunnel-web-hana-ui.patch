+
+public class HanaDataSourceConfig {
+
+    public static final String PLUGIN_NAME = "JDBC-Hana";
+
+    public static final DataSourcePluginInfo HANA_DATASOURCE_PLUGIN_INFO =
+            DataSourcePluginInfo.builder()
+                    .name(PLUGIN_NAME)
+                    .icon(PLUGIN_NAME)
+                    .version("1.0.0")
+                    .type(DatasourcePluginTypeEnum.DATABASE.getCode())
+                    .build();
+
+    public static final Set<String> HANA_SYSTEM_SCHEMAS =
+            Sets.newHashSet(
+                    "SYS",
+                    "SYSTEM",
+                    "PUBLIC",
+                    "_SYS_AFLLANG",
+                    "_SYS_AFL",
+                    "_SYS_BI",
+                    "_SYS_BIC",
+                    "_SYS_DI",
+                    "_SYS_EPM",
+                    "_SYS_REPO",
+                    "_SYS_RT",
+                    "_SYS_SQL_ANALYZER",
+                    "_SYS_STATISTICS",
+                    "_SYS_TASK");
+
+    public static final OptionRule OPTION_RULE =
+            OptionRule.builder()
+                    .required(HanaOptionRule.URL, HanaOptionRule.DRIVER)
+                    .optional(HanaOptionRule.USER, HanaOptionRule.PASSWORD)
+                    .build();
+
+    public static final OptionRule METADATA_RULE =
+            OptionRule.builder().required(HanaOptionRule.DATABASE, HanaOptionRule.TABLE).build();
+}
